# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secrets!
#
# cp .env.example .env

# ─── Telegram Bot Setup ────────────────────────────────────────────────
# 1. Open Telegram, search for @BotFather
# 2. Send /newbot and follow instructions → you get a BOT_TOKEN
# 3. Add your bot to a group OR send it a DM
# 4. To get CHAT_ID: visit https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    after sending any message to the bot — look for "chat":{"id": ...}

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Google AI Studio ──────────────────────────────────────────────────
# Get your API key from https://aistudio.google.com/app/apikey

GOOGLE_API_KEY=your_google_api_key_here

# ─── AI Model Selection ────────────────────────────────────────────────
# gemini-3.1-pro-preview  → most capable
# gemini-2.0-flash        → fast and cheap

AI_MODEL=gemini-3.1-pro-preview

# ─── Collection Settings ───────────────────────────────────────────────
COLLECT_INTERVAL_SECONDS=60
AI_INTERVAL_SECONDS=300
AI_ANALYSIS_WINDOW=10

# ─── Database ──────────────────────────────────────────────────────────
# PostgreSQL connection string (e.g. from Neon, Supabase, or self-hosted)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Security ──────────────────────────────────────────────────────────
# API key required on all endpoints (except /, /readyz, /docs).
# Generate one with: openssl rand -hex 32
API_KEY=your_long_random_secret_here

# ─── Alerting ──────────────────────────────────────────────────────────
# Suppress duplicate Telegram alerts for the same issue (seconds).
# Default 900 = 15 minutes. Set to 0 to disable deduplication.
ALERT_COOLDOWN_SECONDS=900

# ─── Data Retention ────────────────────────────────────────────────────
# Delete metric snapshots older than this many days (runs daily at midnight).
# At 60s intervals: ~525k rows/year without retention.
RETENTION_DAYS=30
